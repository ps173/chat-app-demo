generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  firstName    String
  lastName     String
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  createdRooms Chatroom[] @relation("RoomCreator")
  rooms        Chatroom[] @relation("RoomParticipants")
  messages     Message[]
}

model Chatroom {
  id           String    @id @default(uuid())
  roomName     String
  createdBy    User      @relation("RoomCreator", fields: [createdById], references: [id])
  createdById  String
  participants User[]    @relation("RoomParticipants")
  messages     Message[]
  createdAt    DateTime  @default(now())
}

model Message {
  id        String   @id @default(uuid())
  content   String
  sender    User     @relation(fields: [senderId], references: [id])
  senderId  String
  room      Chatroom @relation(fields: [roomId], references: [id])
  roomId    String
  createdAt DateTime @default(now())
}
